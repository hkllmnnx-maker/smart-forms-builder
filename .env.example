# ============================================
# Smart Forms Builder - Environment variables
# ============================================
# Copy this file to .dev.vars for local development
# For production use: npx wrangler pages secret put <NAME>

# Google OAuth (Required) - from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session / encryption key (Required)
# Generate with: openssl rand -hex 32
SESSION_SECRET=please-change-me-to-a-random-64-char-hex-string

# AI provider configuration (Optional - falls back to rule-based)
# Provider can be: openai | gemini | none
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Public app URL (used for OAuth callbacks and links)
APP_URL=http://localhost:3000
